# 服务端口
PORT=3000
# JWT 密钥,生产环境必须是至少 32 字节的随机值
JWT_SECRET=
# 访客显示 ID 的 HMAC 盐;可选,默认复用 JWT_SECRET,生产环境显式配置时至少 32 字节
GUEST_ID_SALT=
# Redis 地址;生产环境建议设置 REDIS_REQUIRED=true,连接失败则拒绝启动
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=csgofriberg:
REDIS_REQUIRED=false
# PoW 默认约适合移动端亚秒级完成;允许范围 16-24 bit
POW_DIFFICULTY=17
POW_CHALLENGE_TTL_SECONDS=120
POW_TOKEN_TTL_SECONDS=600
# 允许访问 API 与 Socket.IO 的前端来源,逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000
# 仅在应用确实位于一层可信反向代理之后时启用
TRUST_PROXY=false
# 数据库类型: sqlite | pg
DB_CLIENT=sqlite
# sqlite 时为文件路径;pg 时为连接串,如 postgres://user:pass@localhost:5432/csgofriberg
DB_URL=./data/csgofriberg.sqlite3
DB_POOL_MIN=2
DB_POOL_MAX=20
# 管理员通过 ADMIN_USERNAME/ADMIN_PASSWORD + pnpm create-admin 显式创建
ADMIN_USERNAME=
ADMIN_PASSWORD=
