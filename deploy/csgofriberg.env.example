NODE_ENV=production
PORT=3000
TRUST_PROXY=true

# Generate independently: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-bytes
GUEST_ID_SALT=replace-with-another-at-least-32-random-bytes

DB_CLIENT=pg
DB_URL=postgres://csgofriberg:replace-password@127.0.0.1:5432/csgofriberg
DB_POOL_MIN=2
DB_POOL_MAX=20

REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=csgofriberg:
REDIS_REQUIRED=true

# Comma-separated exact browser origins. Do not add a trailing slash.
CORS_ORIGINS=https://example.com

POW_DIFFICULTY=17
POW_CHALLENGE_TTL_SECONDS=120
POW_TOKEN_TTL_SECONDS=600
