IMAGE=ghcr.io/xinhai-ai/csgofriberg:latest
APP_PORT_1=3000
APP_PORT_2=3001
TRUST_PROXY=true

# Generate independently with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-bytes
GUEST_ID_SALT=replace-with-another-at-least-32-random-bytes

POSTGRES_DB=csgofriberg
POSTGRES_USER=csgofriberg
# Use a URL-safe password because DB_URL embeds it directly.
POSTGRES_PASSWORD=replace-with-url-safe-password
# PostgreSQL data directory, relative to this Compose file by default.
PGDATA_PATH=./data/pgdata
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_MS=3000

REDIS_PREFIX=csgofriberg:
REDIS_COMMAND_TIMEOUT_MS=1500
PASSWORD_WORKERS=1
PASSWORD_QUEUE_LIMIT=64
BCRYPT_ROUNDS=8
# 管理员选手 JSON 导入请求体上限，默认 2 MiB。
ADMIN_IMPORT_BODY_LIMIT_BYTES=2097152
DISCONNECT_FORFEIT_MS=30000

# Exact public browser origin, without a trailing slash.
CORS_ORIGINS=https://game.example.com

POW_DIFFICULTY=17
POW_CHALLENGE_TTL_SECONDS=120
POW_TOKEN_TTL_SECONDS=600
SHOW_LEADERBOARD=true
